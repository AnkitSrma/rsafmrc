<section class="section">
  <div class="container">
    <div class="section-heading-row">
      <div>
        {% if section.eyebrow %}<p class="eyebrow">{{ section.eyebrow }}</p>{% endif %}
        {% if section.heading %}<h2>{{ section.heading }}</h2>{% endif %}
      </div>
      <div class="carousel-controls">
        <button type="button" class="carousel-btn" data-carousel-dir="-1" aria-label="Scroll featured milestones left">&#8592;</button>
        <button type="button" class="carousel-btn" data-carousel-dir="1" aria-label="Scroll featured milestones right">&#8594;</button>
      </div>
    </div>
    <div class="carousel-viewport" id="milestoneCarousel">
      {% for post in posts %}
      <article class="carousel-card">
        <div class="carousel-card-year{% if loop.index0 % 2 == 1 %} alt{% endif %}">{{ post.date | dateYear }}</div>
        <div class="carousel-card-body">
          <h3><a class="carousel-card-title" href="/{{ post.slug | postHref }}">{{ post.title }}</a></h3>
          <p>{{ post.body | excerpt }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
<script>
  (function () {
    var track = document.getElementById("milestoneCarousel");
    if (!track) return;
    var card = track.querySelector(".carousel-card");
    var step = card ? card.getBoundingClientRect().width + 20 : 300;
    document.querySelectorAll("[data-carousel-dir]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var dir = parseInt(btn.getAttribute("data-carousel-dir"), 10);
        track.scrollBy({ left: dir * step, behavior: "smooth" });
      });
    });
  })();
</script>
