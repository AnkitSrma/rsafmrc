{% set featuredPosts = posts | byFeaturedOrder %}
<section class="section">
  <div class="container">
    {% if section.eyebrow %}<p class="eyebrow">{{ section.eyebrow }}</p>{% endif %}
    {% if section.heading %}<h2>{{ section.heading }}</h2>{% endif %}
    <div class="spotlight-grid">
      <div class="spotlight-col spotlight-col-main">
        <div class="spotlight-heading">
          <span class="spotlight-bar"></span>
          <h3>Featured milestone</h3>
        </div>
        {% if featuredPosts.length > 0 %}
        {% set post = featuredPosts[0] %}
        <article class="spotlight-card spotlight-card-large">
          <a class="spotlight-card-link" href="/{{ post.slug | postHref }}">
            <img class="spotlight-card-image" src="{{ post.heroImage | mediaUrl }}" alt="{{ post.title }}" width="800" height="500" />
            <span class="spotlight-card-scrim" aria-hidden="true"></span>
            <span class="spotlight-tags">
              {% for tag in post.tags %}<span class="tag-pill">{{ tag.text }}</span>{% endfor %}
            </span>
            <span class="spotlight-card-body">
              <span class="spotlight-card-title">{{ post.title }}</span>
              <span class="spotlight-card-date">{{ post.date | dateLong }} &middot; {{ globalSettings.shortName }}</span>
            </span>
          </a>
        </article>
        {% endif %}
      </div>
      <div class="spotlight-col spotlight-col-side">
        <div class="spotlight-heading">
          <span class="spotlight-bar"></span>
          <h3>More milestones</h3>
          <a class="spotlight-view-all" href="/news.html">View all &rarr;</a>
        </div>
        <div class="spotlight-list">
          {% for post in featuredPosts | slice(1, 3) %}
          <article class="spotlight-card spotlight-card-small">
            <a class="spotlight-card-link" href="/{{ post.slug | postHref }}">
              <img class="spotlight-card-image" src="{{ post.heroImage | mediaUrl }}" alt="{{ post.title }}" width="800" height="500" />
              <span class="spotlight-card-scrim" aria-hidden="true"></span>
              <span class="spotlight-tags">
                {% for tag in post.tags %}<span class="tag-pill">{{ tag.text }}</span>{% endfor %}
              </span>
              <span class="spotlight-card-body">
                <span class="spotlight-card-title">{{ post.title }}</span>
                <span class="spotlight-card-date">{{ post.date | dateLong }} &middot; {{ globalSettings.shortName }}</span>
              </span>
            </a>
          </article>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
