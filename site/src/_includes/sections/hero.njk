<section class="hero">
  <div class="container{% if section.sideCard %} hero-grid{% endif %}">
    <div>
      {% if section.eyebrow %}<p class="eyebrow">{{ section.eyebrow }}</p>{% endif %}
      <h1>{{ section.heading }}</h1>
      {% if section.body %}<div class="hero-copy">{{ section.body | markdown | safe }}</div>{% endif %}
      {% if section.ctaPrimaryLabel or section.ctaSecondaryLabel %}
      <div class="hero-actions">
        {% if section.ctaPrimaryLabel %}<a class="button primary" href="{{ section.ctaPrimaryHref }}">{{ section.ctaPrimaryLabel }}</a>{% endif %}
        {% if section.ctaSecondaryLabel %}<a class="button secondary" href="{{ section.ctaSecondaryHref }}">{{ section.ctaSecondaryLabel }}</a>{% endif %}
      </div>
      {% endif %}
    </div>
    {% if section.sideCard %}
    <div class="hero-card" aria-label="{{ section.sideCard.heading }}">
      <h2>{{ section.sideCard.heading }}</h2>
      {% if section.sideCard.items and section.sideCard.items.length %}
      <ul>
        {% for item in section.sideCard.items %}<li>{{ item.text | markdownInline | safe }}</li>{% endfor %}
      </ul>
      {% endif %}
      {% if section.sideCard.body %}{{ section.sideCard.body | markdown | safe }}{% endif %}
    </div>
    {% endif %}
  </div>
</section>
