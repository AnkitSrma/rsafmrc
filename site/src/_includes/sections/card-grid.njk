<section class="section{% if section.alt %} alt-bg{% endif %}"{% if section.anchor %} id="{{ section.anchor }}"{% endif %}>
  <div class="container">
    {% if section.eyebrow %}<p class="eyebrow">{{ section.eyebrow }}</p>{% endif %}
    {% if section.heading %}<h2>{{ section.heading }}</h2>{% endif %}
    <div class="card-grid">
      {% for card in section.cards %}
      <article class="card"{% if card.anchor %} id="{{ card.anchor }}"{% endif %}>
        <h3>{{ card.heading }}</h3>
        {% if card.body %}{{ card.body | markdown | safe }}{% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>
