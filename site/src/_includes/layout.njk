<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if navCurrent == "home" %}{{ globalSettings.shortName }} | {{ globalSettings.siteName }}{% else %}{{ title }} | {{ globalSettings.shortName }}{% endif %}</title>
    {% if metaDescription %}<meta name="description" content="{{ metaDescription }}" />{% endif %}
    <link rel="stylesheet" href="/assets/styles.css" />
    {% if globalSettings.favicon %}<link rel="icon" href="{{ globalSettings.favicon | mediaUrl }}" />{% endif %}
  </head>
  <body data-nav-current="{{ navCurrent }}">
    <div id="page-loader" class="page-loader" role="status" aria-live="polite">
      <div class="page-loader-mark">
        <span class="page-loader-ring"></span>
        <span class="page-loader-ring delay"></span>
        <img src="{{ globalSettings.logo | mediaUrl }}" alt="{{ globalSettings.shortName }} logo" width="176" height="176" />
      </div>
      <div class="page-loader-bar-track"><span class="page-loader-bar"></span></div>
      <p class="page-loader-label">Loading&hellip;</p>
    </div>
    <noscript><style>.page-loader{display:none!important;}</style></noscript>

    <div class="hero-brand">
      <div class="container hero-brand-inner">
        <a class="brand" href="/index.html">
          <img class="brand-mark" src="{{ globalSettings.logo | mediaUrl }}" alt="{{ globalSettings.shortName }} logo" width="88" height="88" />
          <span class="brand-name">{{ globalSettings.siteName }}</span>
        </a>
      </div>
    </div>

    <header class="site-header">
      <div class="container nav-bar">
        <a class="brand-compact" href="/index.html">
          <img class="brand-compact-mark" src="{{ globalSettings.logo | mediaUrl }}" alt="{{ globalSettings.shortName }} logo" width="40" height="40" />
          <span class="brand-compact-name">{{ globalSettings.shortName }}</span>
        </a>
        <nav class="nav-links" id="primary-nav-links" aria-label="Primary navigation">
          {% for navPage in pages | selectattr("showInNav") | sort(attribute="navOrder") %}
          <a href="/{{ navPage.slug | pageHref }}" data-nav="{{ navPage.slug }}">{{ navPage.navLabel or navPage.title }}</a>
          {% endfor %}
        </nav>
        <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="primary-nav-links" aria-label="Toggle navigation menu">
          <span class="nav-toggle-line"></span>
          <span class="nav-toggle-line"></span>
          <span class="nav-toggle-line"></span>
        </button>
      </div>
    </header>

    {% if navCurrent == "home" %}{% include "marquee.njk" %}{% endif %}

    <main{% if navCurrent == "home" %} id="top"{% endif %}>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-row">
        <p>&copy; {{ "now" | year }} {{ globalSettings.siteName }}.</p>
        <div class="footer-contact">
          <p class="footer-contact-heading">Contact</p>
          {% if globalSettings.footerContactLine %}<p>{{ globalSettings.footerContactLine }}</p>{% endif %}
          {% if navCurrent != "contact" %}<p><a href="/contact.html">Get in touch &rarr;</a></p>{% endif %}
        </div>
      </div>
    </footer>
    <script src="/assets/js/page-loader.js" defer></script>
    <script src="/assets/js/nav.js" defer></script>
  </body>
</html>
