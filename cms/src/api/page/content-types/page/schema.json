{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "A top-level site page built from reusable sections"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "navLabel": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "showInNav": {
      "type": "boolean",
      "default": true
    },
    "navOrder": {
      "type": "integer",
      "default": 0
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "element.hero",
        "section.two-column",
        "section.card-grid",
        "section.post-spotlight",
        "section.post-carousel",
        "section.post-timeline"
      ]
    }
  }
}
